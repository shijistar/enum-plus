{
  "name": "@enum-plus/plugin-i18next-vue",
  "version": "1.0.0",
  "description": "A plugin for enum-plus that supports internationalization of enums through i18next-vue",
  "keywords": [
    "enum",
    "enumeration",
    "enum-plus",
    "plugin",
    "typescript",
    "i18n",
    "i18next",
    "i18next-vue",
    "localization",
    "globalization",
    "internationalization",
    "front-end",
    "node.js",
    "ssr"
  ],
  "homepage": "https://github.com/shijistar/enum-plus",
  "bugs": {
    "url": "https://github.com/shijistar/enum-plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shijistar/enum-plus.git"
  },
  "license": "MIT",
  "author": "李凤宝(Leo) <shijistar@gmail.com>",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "es",
    "es-legacy",
    "LICENSE",
    "CHANGELOG.md",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "run-p build:es build:es-legacy",
    "build:es": "father build",
    "build:es-legacy": "cross-env LEGACY=1 father build",
    "prepublishOnly": "npm run build && npm run test",
    "task:copy-lib": "tsx ../../scripts/copy-lib.ts",
    "test": "jest",
    "test-legacy": "jest -c jest-legacy.config.js",
    "test:browser": "npm run test:browser:bundle && playwright test",
    "test:browser:bundle": "node scripts/browser-test-bundle.js",
    "test:browser:debug": "npm run test:browser:bundle && playwright test --debug",
    "test:browser:ui": "npm run test:browser:bundle && playwright test --ui"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/vue": "^8.1.0",
    "@vue/compiler-sfc": "^3.5.22",
    "@vue/vue3-jest": "^29.2.6",
    "@vueuse/core": "^13.9.0",
    "babel-jest": "^29.7.0",
    "vue": "^3.5.22"
  },
  "peerDependencies": {
    "enum-plus": "^3.0.0",
    "i18next": ">=14.0.1",
    "i18next-vue": ">=2.0.0"
  },
  "packageManager": "npm@10.9.2",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
