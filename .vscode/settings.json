{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "cSpell.words": ["jsoneo", "madhead", "shijistar", "softprops", "tses", "Vuetify"],
  "i18n-ally.localesPaths": [".storybook/locales/langs"],
  "i18n-ally.enabledFrameworks": ["react"],
  "i18n-ally.pathMatcher": "{locale}.json",
  "i18n-ally.extract.autoDetect": true,
  "i18n-ally.displayLanguage": "zh-CN",
  "i18n-ally.enabledParsers": ["json"],
  "i18n-ally.includeSubfolders": false,
  "i18n-ally.review.enabled": false,
  "i18n-ally.keystyle": "flat",
  "i18n-ally.regex.usageMatchAppend": [
    "storyT\\(['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]\\)",
    "title:\\s*['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]",
    "label:\\s*['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]",
    "text:\\s*['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]",
    "name:\\s*['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]",
    "hint:\\s*['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]",
    "placeholder:\\s*['\"]([\\w-_]+?\\.[\\w-_.]+)['\"]"
  ],
  "i18n-ally.fullReloadOnChanged": true,
  "i18n-ally.annotationInPlace": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "commentTranslate.hover.enabled": false
}
